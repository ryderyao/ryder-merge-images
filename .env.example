# Google Analytics 4 — 管理 → 資料串流 → 網站 →「評估 ID」(格式 G-XXXXXXXXXX)
# 部署到 Vercel：Project → Settings → Environment Variables 新增同名變數（Production / Preview 皆可勾）
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 站台顯示名稱（選填；程式預設「大家的工具庫」，若要改名請覆寫）
NEXT_PUBLIC_SITE_NAME=

# 正式網域／canonical／OG 完整網址前綴（本機可設 http://localhost:3000；部署請設 https://你的網域）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Threads 個人檔案完整網址（選填；程式預設 https://www.threads.com/@ryderyao ，若要換帳號請覆寫）
NEXT_PUBLIC_THREADS_URL=
